# Прод-окружение для сервера. Скопировать в .env на сервере и заполнить секреты.
# НЕ коммитить заполненный .env — только этот пример.

APP_NAME="Отклик"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://otcl1ck.ru

# Разведение по доменам (поддомен business — кабинет/админка/вход)
MARKETING_DOMAIN=otcl1ck.ru
BUSINESS_DOMAIN=business.otcl1ck.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# БД (контейнер pgsql) — задайте СИЛЬНЫЙ пароль
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=otklick
DB_USERNAME=otklick
DB_PASSWORD=__СМЕНИТЕ_НА_СИЛЬНЫЙ_ПАРОЛЬ__

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true

OCTANE_SERVER=roadrunner

# Telegram (бот работает через long polling — вебхуки в РФ недоступны)
TELEGRAM_API_URL=https://api.telegram.org

# LLM: YandexGPT (OpenAI-совместимый эндпоинт)
LLM_DRIVER=yandexgpt
YANDEX_API_KEY=
YANDEX_FOLDER_ID=b1g6dp5rh3eco40qd7eh
YANDEX_GPT_MODEL=aliceai-llm

# YClients (опционально)
YCLIENTS_API_URL=https://api.yclients.com/api/v1
# YCLIENTS_PARTNER_TOKEN=
