APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Error-tracking (Sentry-совместимый сборщик; рекомендуем self-hosted GlitchTip в РФ — 152-ФЗ).
# Пусто = выключено (SDK молчит). Получить DSN: в GlitchTip заведи проект → Settings → DSN.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
# Только ошибки, без performance-трейсинга (легче для GlitchTip). PII не отправляем.
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false
# Ссылка на дашборд трекера — показывается супер-админу в меню («Ошибки ↗»).
ERROR_TRACKING_URL=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Реалтайм (Laravel Reverb / WebSocket). Включается BROADCAST_CONNECTION=reverb,
# когда поднят контейнер reverb. На проде WSS проксируется Caddy на том же домене
# (путь /app/* → reverb), поэтому REVERB_HOST=business.otcl1ck.ru, PORT=443, SCHEME=https.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Для Echo на фронте (Vite пробрасывает в браузер):
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Telegram-канал (работает через long polling — telegram:poll; вебхуки в РФ недоступны)
TELEGRAM_API_URL=https://api.telegram.org
# На прод-сервере в РФ: api.telegram.org заблокирован по IPv4, доступен по IPv6.
# Включить, чтобы запросы к Telegram сразу шли по IPv6 (без IPv4-таймаута).
TELEGRAM_FORCE_IPV6=false

# YClients (CRM)
YCLIENTS_API_URL=https://api.yclients.com/api/v1
# Партнёрский токен приложения (общий для платформы)
# YCLIENTS_PARTNER_TOKEN=

# LLM: fake (локально, без ключей) | gigachat | yandexgpt
LLM_DRIVER=fake
# GIGACHAT_CLIENT_ID=
# GIGACHAT_CLIENT_SECRET=
# Для LLM_DRIVER=yandexgpt: ключ + folder_id каталога Yandex Cloud.
# Используется OpenAI-совместимый эндпоинт Yandex Cloud AI (по умолчанию).
# В Yandex AI Studio модель называется aliceai-llm.
# YANDEX_API_KEY=
# YANDEX_FOLDER_ID=
# YANDEX_GPT_MODEL=aliceai-llm
# YANDEX_API_URL=https://ai.api.cloud.yandex.net/v1/chat/completions

# Распознавание изображений: fake (бот «не видит» фото, отдаёт администратору) |
# yandex (vision-модель Yandex Cloud по OpenAI-совместимому эндпоинту). Модель
# должна быть vision-способной (Qwen-VL / Gemma-3 и т.п.); ключ/folder — общие YANDEX_*.
VISION_DRIVER=fake
# VISION_MODEL=qwen3.6-35b-a3b   # vision-модель Yandex Cloud (reasoning-типа)

VITE_APP_NAME="${APP_NAME}"
