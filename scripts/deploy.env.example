# Доступы к прод-серверу для scripts/deploy.sh.
# Скопируйте в scripts/deploy.env (он в .gitignore) и впишите реальные значения.
# В репозиторий настоящие доступы НЕ коммитим — он публичный.

OTKLIK_DEPLOY_HOST=
OTKLIK_DEPLOY_USER=root
OTKLIK_DEPLOY_KEY=$HOME/.ssh/otklick_deploy
OTKLIK_DEPLOY_PATH=/opt/otklick
